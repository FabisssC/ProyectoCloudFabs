PROJECT_ENV=dev

# Local paths
DATA_DIR=./data_sources
OUTPUT_DIR=./out
STATE_PATH=./out/state.json

# Cloud target
CLOUD_PROVIDER=gcp

# GCP
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCS_BUCKET=your-bucket
GCS_PREFIX=fraud_medallion

# BigQuery
BQ_DATASET_BRONZE=bronze
BQ_DATASET_SILVER=silver
BQ_DATASET_GOLD=gold

# Source: transactions and merchants
ELO_HISTORICAL_TRANSACTIONS_PATH=./data_sources/elo/historical_transactions.csv
ELO_NEW_MERCHANT_TRANSACTIONS_PATH=./data_sources/elo/new_merchant_transactions.csv
ELO_MERCHANTS_PATH=./data_sources/elo/merchants.csv

# Source: FX API
FX_PROVIDER=ecb
FX_BASE_CURRENCY=EUR
FX_TARGET_CURRENCY=USD
FREECURRENCYAPI_KEY=
FX_OUTPUT_PATH=./data_sources/fx/
